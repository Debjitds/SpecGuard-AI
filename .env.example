# ---------------------------------------------------------------------------
# SpecGuard AI — environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` (or `.env.local`) and fill in your values.
#
# IMPORTANT: The app runs FULLY without any of these set — it transparently
# falls back to a local (browser) backend + a built-in analyzer. Provide these
# only when you want real Supabase persistence and Gemini AI analysis.
# ---------------------------------------------------------------------------

# Supabase — Project Settings → API
# Leave both empty to use the local fallback backend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Gemini API key — https://aistudio.google.com/app/apikey
# Leave empty to use the built-in deterministic analyzer.
VITE_GEMINI_API_KEY=
